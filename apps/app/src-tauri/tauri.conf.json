{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pupil",
  "version": "0.0.1",
  "identifier": "com.pupil.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pupil",
        "width": 1280,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true,
        "theme": "Dark"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
